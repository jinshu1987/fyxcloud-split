# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://fyxcloud:CHANGEME@localhost:5432/fyxcloud
POSTGRES_DB=fyxcloud
POSTGRES_USER=fyxcloud
POSTGRES_PASSWORD=CHANGEME

# ─── Security ─────────────────────────────────────────────────────
# SESSION_SECRET: at least 64 random characters
SESSION_SECRET=CHANGEME_REPLACE_WITH_64_CHAR_RANDOM_STRING

# ENCRYPTION_KEY: exactly 64 hex chars (32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGEME_64_HEX_CHARACTERS

# ─── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGEME
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
STRIPE_STARTER_MONTHLY_PRICE_ID=price_CHANGEME
STRIPE_STARTER_ANNUAL_PRICE_ID=price_CHANGEME
STRIPE_PRO_MONTHLY_PRICE_ID=price_CHANGEME
STRIPE_PRO_ANNUAL_PRICE_ID=price_CHANGEME
STRIPE_ENT_MONTHLY_PRICE_ID=price_CHANGEME
STRIPE_ENT_ANNUAL_PRICE_ID=price_CHANGEME

# ─── App ──────────────────────────────────────────────────────────
APP_URL=https://your-domain.com
NODE_ENV=production
